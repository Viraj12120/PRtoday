# =============================================================================
# PR Today V2 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.
# =============================================================================

# GitHub Personal Access Token (required)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Model — LiteLLM-compatible identifier (required)
AI_MODEL=gemini/gemini-2.5-flash

# Optional AI provider keys (set the one matching your AI_MODEL)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL Database URL — asyncpg driver (required for API server)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/prtoday

# Redis URL — used for caching analysis results (optional)
REDIS_URL=redis://localhost:6379/0

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
